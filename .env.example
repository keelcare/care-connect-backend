# Application Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5433/database_name
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Google Maps API (for location features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Gemini AI API (for AI matching recommendations)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay (for payments) - REQUIRED in production
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email Configuration (for nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com 
EMAIL_PASSWORD=your_email_password

# Sentry Configuration
SENTRY_DSN=https://your_sentry_dsn_here

# Twilio Configuration (for SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_from_number_here

# GST
# When enabled, GST_PERCENT is added on top of the subtotal and the customer is
# charged the tax-inclusive amount. Flipping this changes what customers pay.
# Each price_snapshot records the rate applied at charge time, so past charges
# are unaffected by a later flip.
GST_ENABLED=false
GST_PERCENT=18

# Universal / App Links (keelcare.in)
# Served at /.well-known/* for iOS/Android domain verification once keelcare.in
# points at this backend. Leave unset to serve 404 (links stay disabled).
# APPLE_TEAM_ID=AB12CD34EF
# ANDROID_CERT_SHA256=AA:BB:CC:...  (from `eas credentials`; comma-separate multiple)

# WebRTC calling (in-app parent <-> nanny calls)
# TURN relay credentials from metered.ca (free tier). Unset = STUN-only
# (calls on strict carrier NATs may fail to connect).
METERED_DOMAIN=yourapp.metered.live
METERED_API_KEY=your_metered_api_key_here

# Direct APNs push (iOS registers raw APNs tokens firebase-admin can't send to).
# .p8 auth key from the Apple Developer portal.
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apple_team_id
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APNS_BUNDLE_ID=com.keel.careconnect
# Set to false to target the APNs sandbox (development builds)
APNS_PRODUCTION=true
